# CropSense backend environment
GROK_API_KEY=replace_with_xai_grok_key
GROK_MODEL=grok-4.3
GROK_VISION_MODEL=grok-4
GROK_TIMEOUT_SECONDS=35

# Local development database. Use Oracle variables or DATABASE_URL in production.
DATABASE_URL=sqlite:///./cropsense_dev.db
AUTH_SECRET_KEY=replace_with_long_random_secret

# Oracle alternative for production if DATABASE_URL is not used.
# ORACLE_USER=replace_with_oracle_user
# ORACLE_PASSWORD=replace_with_oracle_password
# ORACLE_HOST=replace_with_oracle_host
# ORACLE_PORT=1521
# ORACLE_SERVICE_NAME=replace_with_service_name

# Deployment CORS. Set this to the frontend URL on Render/Vercel/Netlify.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,https://your-netlify-site.netlify.app
CORS_ALLOW_ALL=false
